# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info

# Keep lock files versioned (reproducible provider resolution)
!.terraform.lock.hcl

# Go
apps/**/bin/
*.test
coverage.out

# Node
node_modules/
apps/costwatch/frontend/dist/

# costwatch: embedded SPA build output — rebuilt by `make frontend-build`; the
# backend serves an in-code hint page when dist is empty (fresh clone still builds)
apps/costwatch/backend/web/dist/*
!apps/costwatch/backend/web/dist/.gitkeep

# Editors / OS
.DS_Store
.idea/
*.swp

# Local env & secrets — never commit
.env
.env.*
*.pem
kubeconfig*

# k6 outputs
load/k6/results/
